# ============================================
# CUADERNO - Configuración de Variables de Entorno
# ============================================

# Flask Configuration
FLASK_APP=backend.main
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True

# Database
# SQLite for development
# DATABASE_URL=sqlite:///cuaderno.db

# PostgreSQL for production (uncomment and configure)
DATABASE_URL=postgresql://postgres:Liana102816@localhost:5432/cuaderno

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=604800  # 7 days

# CORS Configuration (comma separated)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per minute

# Business Configuration
DEFAULT_CURRENCY=COP
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_LOCALE=es_CO

# Free Plan Limits
FREE_MAX_BUSINESSES=1
FREE_MAX_PRODUCTS=20
FREE_MAX_CUSTOMERS=10
FREE_MAX_RECORDS_PER_MONTH=100

# Pro Plan Features
PRO_UNLIMITED_BUSINESSES=True
PRO_UNLIMITED_PRODUCTS=True
PRO_UNLIMITED_CUSTOMERS=True
PRO_AUTO_BACKUP=True
PRO_MULTI_USER=True

# Pricing (COP)
PRO_MONTHLY_PRICE_COP=19900
PRO_ANNUAL_DISCOUNT=0.15

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MP_NEQUI_ENABLED=True
MP_CARD_ENABLED=True
MP_SUCCESS_URL=https://tu-dominio.com/pago/exito
MP_FAILURE_URL=https://tu-dominio.com/pago/fallo
MP_PENDING_URL=https://tu-dominio.com/pago/pendiente

# Export Configuration
EXPORT_MAX_ROWS=10000
EXPORT_DIR=exports

# Backup Configuration
BACKUP_DIR=backups
MAX_BACKUPS=10

# Admin User (created automatically on first run)
ADMIN_EMAIL=admin@cuaderno.app
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# Logging
LOG_LEVEL=INFO
LOG_FILE=cuaderno.log

EMAIL_PROVIDER=smtp

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@encajapp.site
SMTP_PASS=Liana102816@
SMTP_FROM=no-reply@encajapp.site

PUBLIC_BASE_URL=https://encajapp.site
