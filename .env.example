# ============================================
# CUADERNO - Configuración de Variables de Entorno
# ============================================

# Flask Configuration
FLASK_APP=backend.main
APP_ENV=development
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-key
JWT_SECRET_KEY=change-this-to-a-different-long-random-jwt-secret
DEBUG=true
EXPOSE_ERROR_DETAILS=true

# Database
# PostgreSQL is required by default.
# For explicit local-only SQLite fallback, set ALLOW_SQLITE_FALLBACK=true and provide SQLITE_DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cuaderno
SQLITE_DATABASE_URL=sqlite:///cuaderno.db
ALLOW_SQLITE_FALLBACK=false
ALLOW_RUNTIME_SCHEMA_MUTATIONS=false
ALLOW_STARTUP_DATA_BOOTSTRAP=false

# JWT Configuration
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=604800  # 7 days

# CORS Configuration (comma separated). Para la app móvil (Capacitor) el backend añade automáticamente capacitor://localhost y https://app.encaja.co.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
CLIENT_URL=http://localhost:5173
PORT=5000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100 per minute

# Business Configuration
DEFAULT_CURRENCY=COP
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_LOCALE=es_CO

# Free Plan Limits
FREE_MAX_BUSINESSES=1
FREE_MAX_PRODUCTS=20
FREE_MAX_CUSTOMERS=10
FREE_MAX_RECORDS_PER_MONTH=100

# Pro Plan Features
PRO_UNLIMITED_BUSINESSES=True
PRO_UNLIMITED_PRODUCTS=True
PRO_UNLIMITED_CUSTOMERS=True
PRO_AUTO_BACKUP=True
PRO_MULTI_USER=True

# Pricing (COP)
PRO_MONTHLY_PRICE_COP=19900
PRO_ANNUAL_DISCOUNT=0.15

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MP_NEQUI_ENABLED=True
MP_CARD_ENABLED=True
WOMPI_ENV=prod
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
MP_SUCCESS_URL=https://tu-dominio.com/pago/exito
MP_FAILURE_URL=https://tu-dominio.com/pago/fallo
MP_PENDING_URL=https://tu-dominio.com/pago/pendiente

# Export Configuration
EXPORT_MAX_ROWS=10000
EXPORT_DIR=exports

# Backup Configuration
BACKUP_DIR=backups
MAX_BACKUPS=10

# Admin bootstrap (manual and explicit only; normal startup/import does not create or update admin)
ADMIN_EMAIL=admin@cuaderno.app
ADMIN_PASSWORD=
ADMIN_NAME=Administrador

# Logging
LOG_LEVEL=INFO
LOG_FILE=cuaderno.log
