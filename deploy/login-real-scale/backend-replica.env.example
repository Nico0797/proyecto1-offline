APP_ENV=production
FLASK_ENV=production
DEBUG=false
PORT=8000
DATABASE_URL=postgresql://postgres:postgres@DB_PRIVATE_HOST:5432/cuaderno
REDIS_URL=redis://REDIS_PRIVATE_HOST:6379/0
SECRET_KEY=REPLACE_WITH_STRONG_SECRET
JWT_SECRET_KEY=REPLACE_WITH_DIFFERENT_STRONG_SECRET
CLIENT_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com
APP_STATIC_DIR=/app/backend/static_dist
ALLOW_SQLITE_FALLBACK=false
ALLOW_RUNTIME_SCHEMA_MUTATIONS=false
ALLOW_STARTUP_DATA_BOOTSTRAP=false
EXPOSE_ERROR_DETAILS=false
GUNICORN_WORKERS=4
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
SQLALCHEMY_POOL_SIZE=8
SQLALCHEMY_MAX_OVERFLOW=4
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=300
SHARED_RESPONSE_CACHE_ENABLED=true
SHARED_RESPONSE_CACHE_PREFIX=cuaderno
LOG_LEVEL=INFO
